# Configurações do Servidor
PORT=8000
HOST=0.0.0.0

# Banco de Dados (SQLite por padrão para desenvolvimento local, PostgreSQL para produção)
# Exemplo de SQLite: sqlite:///./trade_scanner.db
# Exemplo de Postgres: postgresql://usuario:senha@localhost:5432/trade_scanner
DATABASE_URL=sqlite:///./trade_scanner.db

# Configuração de Modo Mock (Geração de dados simulados caso não tenha chaves de API)
MOCK_MODE=true

# Chaves de API das Fontes de Dados (Obrigatório apenas se MOCK_MODE=false)
THE_ODDS_API_KEY=seu_token_aqui
FOOTBALL_DATA_API_KEY=seu_token_aqui

# Chave de API do Google Gemini (Para o assistente de IA explicar as análises)
GEMINI_API_KEY=sua_chave_gemini_aqui
